{
  "name": "@chatwoot/mobile-app",
  "version": "4.0.22",
  "volta": {
    "node": "20.19.6",
    "pnpm": "9.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "patch-package",
    "eas-build-pre-install": "bash scripts/eas-build-pre-install.sh",
    "start": "expo start --dev-client",
    "start:prod": "expo start --no-dev --minify",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "generate": "npx expo prebuild --clean",
    "generate:soft": "npx expo prebuild",
    "generate:fast": "npx expo prebuild --no-install",
    "build:metrics": "./scripts/track-build-time.sh",
    "doctor": "npx expo-doctor",
    "clean": "watchman watch-del-all && pnpm cache clean",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "eas:build:ios": "eas build -p ios --profile production",
    "eas:build:ios:local": "eas build -p ios --profile production --local",
    "eas:build:android": "eas build -p android --profile production",
    "eas:build:android:local": "eas build -p android --profile production --local",
    "expo:env:pull:dev": "./scripts/pull-expo-env.sh development",
    "expo:env:pull:prod": "./scripts/pull-expo-env.sh production",
    "firebase:setup": "./scripts/setup-firebase-credentials.sh",
    "storybook": "expo start",
    "storybook:generate": "sb-rn-get-stories",
    "adb:connect": "adb reverse tcp:9090 tcp:9090",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.93",
    "@alantoa/lightbox": "^0.3.1",
    "@chatwoot/markdown-to-txt": "^2.0.4",
    "@chatwoot/react-native-widget": "^0.0.21",
    "@chatwoot/utils": "^0.0.33",
    "@gorhom/bottom-sheet": "^5.1.2",
    "@kesha-antonov/react-native-action-cable": "^1.1.5",
    "@nandorojo/galeria": "^1.2.0",
    "@notifee/react-native": "^9.1.1",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-clipboard/clipboard": "^1.6.1",
    "@react-native-community/blur": "^4.4.1",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-community/slider": "^5.1.2",
    "@react-native-firebase/analytics": "^23.5.0",
    "@react-native-firebase/app": "^23.5.0",
    "@react-native-firebase/messaging": "^23.5.0",
    "@react-native-firebase/perf": "^23.5.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.10.1",
    "@reduxjs/toolkit": "^2.5.1",
    "@sentry/react-native": "^6.10.0",
    "@shopify/flash-list": "^1.7.3",
    "ai": "5.0.93",
    "axios": "^1.6.4",
    "camelcase": "^8.0.0",
    "camelcase-keys": "^7.0.2",
    "date-fns": "2.21.1",
    "diff": "5.0.0",
    "expo": "~52.0.48",
    "expo-application": "~6.0.2",
    "expo-auth-session": "~6.0.3",
    "expo-av": "~15.0.2",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "^17.0.8",
    "expo-dev-client": "~5.0.20",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-image": "~2.0.7",
    "expo-linking": "~7.0.5",
    "expo-localization": "~16.0.1",
    "expo-notifications": "~0.29.14",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.9",
    "expo-updates": "~0.27.4",
    "expo-web-browser": "~14.0.2",
    "i18n-js": "^3.8.0",
    "lodash": "^4.17.21",
    "lucide-react-native": "^0.575.0",
    "react": "18.3.1",
    "react-hook-form": "^7.52.1",
    "react-native": "0.76.9",
    "react-native-audio-recorder-player": "^3.6.11",
    "react-native-autoheight-webview": "^1.6.5",
    "react-native-device-info": "^11.1.0",
    "react-native-document-picker": "^9.3.1",
    "react-native-file-viewer": "^2.1.5",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.20.2",
    "react-native-image-picker": "^7.1.2",
    "react-native-ios-context-menu": "^3.1.0",
    "react-native-ios-utilities": "5.1.1",
    "react-native-keyboard-controller": "^1.16.0",
    "react-native-markdown-display": "^7.0.0-alpha.2",
    "react-native-pager-view": "^6.5.1",
    "react-native-permissions": "^5.2.4",
    "react-native-reanimated": "3.16.7",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "^4.4.0",
    "react-native-snackbar": "^2.8.0",
    "react-native-svg": "^15.8.0",
    "react-native-webview": "^13.12.5",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rn-fetch-blob": "^0.12.0",
    "semver": "^7.6.3",
    "snakecase-keys": "^8.0.1",
    "string.prototype.matchall": "4.0.3",
    "tsyringe": "^4.10.0",
    "twrnc": "^4.5.1",
    "use-deep-compare-effect": "^1.8.1",
    "zeego": "^2.0.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@storybook/addon-ondevice-actions": "^8.5.2",
    "@storybook/addon-ondevice-controls": "^8.5.2",
    "@storybook/react-native": "^8.5.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/i18n-js": "^3.8.9",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.24",
    "@types/react": "~18.3.18",
    "@ungap/structured-clone": "^1.3.0",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "babel-plugin-transform-typescript-metadata": "^0.4.0",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^8.0.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "jest": "^29.6.3",
    "lint-staged": "^16.3.0",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.3.3",
    "react-dom": "18.3.1",
    "react-test-renderer": "^18.3.1",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.1.3",
    "web-streams-polyfill": "^4.2.0"
  },
  "pnpm": {
    "overrides": {
      "web-streams-polyfill": "^4.2.0"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "@kesha-antonov/react-native-action-cable"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "enabled": true,
        "exclude": [
          "@kesha-antonov/react-native-action-cable",
          "react-native-audio-recorder-player",
          "react-native-document-picker",
          "react-native-file-viewer",
          "react-native-file-viewer",
          "react-native-fs",
          "react-native-snackbar",
          "@react-native-community/blur",
          "react-native-autoheight-webview",
          "redux-persist",
          "rn-fetch-blob",
          "@chatwoot/markdown-to-txt",
          "@chatwoot/react-native-widget",
          "@chatwoot/utils",
          "camelcase",
          "camelcase-keys",
          "date-fns",
          "lodash",
          "use-deep-compare-effect",
          "diff",
          "string.prototype.matchall",
          "snakecase-keys"
        ],
        "listUnknownPackages": true
      }
    }
  }
}
