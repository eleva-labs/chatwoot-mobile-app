{
  "name": "@chatwoot/mobile-app",
  "version": "4.2.0",
  "volta": {
    "node": "20.19.6",
    "pnpm": "9.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "patch-package",
    "eas-build-pre-install": "bash scripts/eas-build-pre-install.sh",
    "start": "expo start --dev-client",
    "start:prod": "expo start --no-dev --minify",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "generate": "npx expo prebuild --clean",
    "generate:soft": "npx expo prebuild",
    "generate:fast": "npx expo prebuild --no-install",
    "build:metrics": "./scripts/track-build-time.sh",
    "doctor": "npx expo-doctor",
    "clean": "watchman watch-del-all && pnpm cache clean",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "eas:build:ios": "eas build -p ios --profile production",
    "eas:build:ios:local": "eas build -p ios --profile production --local",
    "eas:build:android": "eas build -p android --profile production",
    "eas:build:android:local": "eas build -p android --profile production --local",
    "expo:env:pull:dev": "./scripts/pull-expo-env.sh development",
    "expo:env:pull:prod": "./scripts/pull-expo-env.sh production",
    "firebase:setup": "./scripts/setup-firebase-credentials.sh",
    "storybook:start": "expo start",
    "storybook:generate": "sb-rn-get-stories",
    "adb:connect": "adb reverse tcp:9090 tcp:9090",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.93",
    "@alantoa/lightbox": "^0.3.1",
    "@chatwoot/markdown-to-txt": "^2.0.4",
    "@chatwoot/react-native-widget": "^0.0.21",
    "@chatwoot/utils": "^0.0.52",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@kesha-antonov/react-native-action-cable": "^1.1.5",
    "@nandorojo/galeria": "^2.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-community/slider": "^5.1.2",
    "@react-native-documents/picker": "^12.0.1",
    "@react-native-firebase/analytics": "^23.8.6",
    "@react-native-firebase/app": "^23.8.6",
    "@react-native-firebase/messaging": "^23.8.6",
    "@react-native-firebase/perf": "^23.8.6",
    "@react-native-menu/menu": "^2.0.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.10.1",
    "@reduxjs/toolkit": "^2.5.1",
    "@ronradtke/react-native-markdown-display": "^8.1.0",
    "@sentry/react-native": "^7.11.0",
    "@shopify/flash-list": "^2.3.0",
    "ai": "5.0.93",
    "axios": "^1.13.6",
    "camelcase": "^8.0.0",
    "camelcase-keys": "^7.0.2",
    "date-fns": "^4.1.0",
    "diff": "^7.0.0",
    "expo": "~55.0.5",
    "expo-application": "~55.0.9",
    "expo-auth-session": "~55.0.8",
    "expo-blur": "^55.0.9",
    "expo-build-properties": "~55.0.9",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "^55.0.7",
    "expo-dev-client": "~55.0.16",
    "expo-device": "~55.0.9",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-image-manipulator": "^55.0.10",
    "expo-image-picker": "~55.0.12",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.8",
    "expo-notifications": "~55.0.12",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-updates": "~55.0.13",
    "expo-video": "~55.0.10",
    "expo-web-browser": "~55.0.9",
    "i18n-js": "^4.5.3",
    "lodash": "^4.17.23",
    "lucide-react-native": "^0.575.0",
    "react": "19.2.0",
    "react-hook-form": "^7.52.1",
    "react-native": "~0.83.2",
    "react-native-audio-recorder-player": "^3.6.14",
    "react-native-blob-util": "^0.24.7",
    "react-native-file-viewer": "^2.1.5",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-ios-context-menu": "^3.2.1",
    "react-native-ios-utilities": "^5.2.0",
    "react-native-keyboard-controller": "^1.20.7",
    "react-native-pager-view": "^8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-snackbar": "^3.0.1",
    "react-native-svg": "^15.15.3",
    "react-native-webview": "^13.16.0",
    "react-native-worklets": "0.7.2",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "semver": "^7.6.3",
    "snakecase-keys": "^8.0.1",
    "tsyringe": "^4.10.0",
    "twrnc": "^4.16.0",
    "use-deep-compare-effect": "^1.8.1",
    "zeego": "^3.0.6",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@storybook/addon-ondevice-actions": "^8.5.2",
    "@storybook/addon-ondevice-controls": "^8.5.2",
    "@storybook/react-native": "^8.5.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.24",
    "@types/react": "~19.2.14",
    "@ungap/structured-clone": "^1.3.0",
    "babel-plugin-transform-typescript-metadata": "^0.4.0",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.2.1",
    "expo-build-disk-cache": "^0.7.2",
    "husky": "^9.1.7",
    "jest": "^29.6.3",
    "lint-staged": "^16.3.0",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.3.3",
    "react-dom": "19.2.0",
    "react-test-renderer": "19.2.0",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "web-streams-polyfill": "^4.2.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "react-test-renderer": "19.2.0",
      "web-streams-polyfill": "^4.2.0"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "@shopify/flash-list",
        "@kesha-antonov/react-native-action-cable",
        "@react-native-community/netinfo"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "enabled": true,
        "exclude": [
          "@kesha-antonov/react-native-action-cable",
          "react-native-audio-recorder-player",
          "react-native-file-viewer",
          "react-native-snackbar",
          "redux-persist",
          "@chatwoot/markdown-to-txt",
          "@chatwoot/react-native-widget",
          "@chatwoot/utils",
          "camelcase",
          "camelcase-keys",
          "lodash",
          "use-deep-compare-effect",
          "diff",
          "snakecase-keys"
        ],
        "listUnknownPackages": true
      }
    }
  }
}
