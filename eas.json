{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "cache": {
        "disabled": false,
        "key": "sdk55-v1",
        "cacheDefaultPaths": true
      }
    },
    "development:simulator": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "cache": {
        "key": "sdk55-dev-sim-v1"
      },
      "ios": {
        "simulator": true
      },
      "env": {
        "ENVIRONMENT": "dev"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "store",
      "cache": {
        "key": "sdk55-dev-v1"
      },
      "env": {
        "ENVIRONMENT": "dev",
        "EAS_BUILD_PROFILE": "development",
        "SENTRY_ORG": "eleva-labs",
        "SENTRY_PROJECT": "chatscommerce",
        "EXPO_DEBUG": "1"
      },
      "environment": "development",
      "channel": "development",
      "android": {
        "image": "latest",
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleDebug",
        "env": {
          "ENVIRONMENT": "dev"
        }
      },
      "ios": {
        "image": "latest"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "cache": {
        "key": "sdk55-preview-v1"
      },
      "env": {
        "ENVIRONMENT": "dev",
        "EAS_BUILD_PROFILE": "preview",
        "SENTRY_ORG": "eleva-labs",
        "SENTRY_PROJECT": "chatscommerce"
      },
      "environment": "preview",
      "channel": "preview",
      "ios": {
        "image": "latest"
      },
      "android": {
        "image": "latest",
        "buildType": "apk"
      }
    },
    "staging": {
      "extends": "production",
      "cache": {
        "key": "sdk55-staging-v2"
      },
      "env": {
        "ENVIRONMENT": "prod",
        "SENTRY_ORG": "eleva-labs",
        "SENTRY_PROJECT": "chatscommerce"
      },
      "environment": "development",
      "channel": "staging"
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "cache": {
        "key": "sdk55-prod-v1"
      },
      "env": {
        "ENVIRONMENT": "prod",
        "SENTRY_ORG": "eleva-labs",
        "SENTRY_PROJECT": "chatscommerce"
      },
      "environment": "production",
      "channel": "production",
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease",
        "image": "latest"
      },
      "ios": {
        "image": "latest"
      }
    }
  },
  "submit": {
    "development": {
      "android": {
        "serviceAccountKeyPath": "./credentials/android/service-account-key.json",
        "track": "internal"
      },
      "ios": {
        "ascAppId": "6749920971",
        "appleTeamId": "TGB3VRK9LR"
      }
    },
    "staging": {
      "android": {
        "serviceAccountKeyPath": "./credentials/android/service-account-key.json",
        "track": "internal"
      },
      "ios": {
        "ascAppId": "6749920971",
        "appleTeamId": "TGB3VRK9LR"
      }
    },
    "production": {
      "android": {
        "serviceAccountKeyPath": "./credentials/android/service-account-key.json",
        "track": "internal"
      },
      "ios": {
        "ascAppId": "6749920971",
        "appleTeamId": "TGB3VRK9LR"
      }
    }
  }
}
