# =============================================================================
# Chatscommerce Mobile App - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# For team members: Use `pnpm run env:merge:dev` to pull and merge EAS secrets.
#
# Most variables have working defaults for local development.
# Only variables marked with "# TODO:" need to be filled in manually.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=dev

# -----------------------------------------------------------------------------
# Expo/EAS Project
# -----------------------------------------------------------------------------
EXPO_PUBLIC_PROJECT_ID=c388de6e-16cf-4618-b94e-a45c450845dc
EXPO_PUBLIC_APP_SLUG=chatscommerce

# -----------------------------------------------------------------------------
# Chatwoot API
# -----------------------------------------------------------------------------
EXPO_PUBLIC_BASE_URL=https://dev.app.chatscommerce.com
EXPO_PUBLIC_INSTALLATION_URL=https://dev.app.chatscommerce.com/
EXPO_PUBLIC_CHATWOOT_BASE_URL=https://dev.app.chatscommerce.com
EXPO_PUBLIC_CHATWOOT_WEBSITE_TOKEN=
EXPO_PUBLIC_MINIMUM_CHATWOOT_VERSION=3.13.0

# -----------------------------------------------------------------------------
# Firebase & Google Services
# -----------------------------------------------------------------------------
# Firebase Project ID (dev: chatscommerce-dev, prod: chatscommerce-ec2f7)
FIREBASE_PROJECT_ID=chatscommerce-dev

# Native credential file paths (used by native builds)
GOOGLE_SERVICES_JSON=./credentials/android/google-services-dev.json
GOOGLE_SERVICE_INFO_PLIST=./credentials/ios/GoogleService-Info-dev.plist

# Expo-specific paths (used by app.config.ts)
EXPO_PUBLIC_IOS_GOOGLE_SERVICES_FILE=./credentials/ios/GoogleService-Info-dev.plist
EXPO_PUBLIC_ANDROID_GOOGLE_SERVICES_FILE=./credentials/android/google-services-dev.json

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# S3 bucket for onboarding assets
EXPO_PUBLIC_S3_BASE_URL=https://chatscomm-ai-backend-dev.s3.amazonaws.com

# TODO: Get OpenAI API key from OpenAI dashboard (keep secret!)
EXPO_PUBLIC_OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Analytics & Monitoring
# -----------------------------------------------------------------------------
# TODO: Get Sentry DSN from Sentry project settings
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_PROJECT_NAME=chatscommerce
EXPO_PUBLIC_SENTRY_ORG_NAME=eleva-labs

# TODO: Get June SDK key from June dashboard
EXPO_PUBLIC_JUNE_SDK_KEY=

# TODO: Get Sentry auth token for source map uploads (keep secret!)
# SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Build & CI Configuration
# -----------------------------------------------------------------------------
EXPO_STORYBOOK_ENABLED=false
SENTRY_DISABLE_AUTO_UPLOAD=true

# TODO: Fill in for iOS App Store submissions
# EXPO_APPLE_ID=
# EXPO_APPLE_TEAM_ID=
