# ===========================================
# Chatscommerce Mobile App - Environment Variables
# ===========================================
# Quick Setup:
#   1. cp .env.example .env
#   2. Fill in the values below
#   3. Run: direnv allow . (if using direnv)
#
# IMPORTANT: Never commit .env - it's gitignored!

# -------------------------------------------
# Local Development Only (not synced to EAS)
# -------------------------------------------
# Helicone API Key (for OpenCode MCP observability)
# Get yours at: https://us.helicone.ai/settings/api-keys
HELICONE_API_KEY=sk-helicone-your-key-here

# Build Configuration
SIMULATOR=1                      # 1=simulator, 0=device
SENTRY_DISABLE_AUTO_UPLOAD=true  # Disable Sentry uploads locally

# -------------------------------------------
# Build Configuration
# -------------------------------------------
# Environment: dev | prod
ENVIRONMENT=

# -------------------------------------------
# App Configuration
# -------------------------------------------
EXPO_PUBLIC_APP_SLUG=chatscommerce
EXPO_PUBLIC_PROJECT_ID=
EXPO_PUBLIC_BASE_URL=
EXPO_PUBLIC_INSTALLATION_URL=
EXPO_PUBLIC_MINIMUM_CHATWOOT_VERSION=

# -------------------------------------------
# Chatwoot Integration
# -------------------------------------------
EXPO_PUBLIC_CHATWOOT_WEBSITE_TOKEN=
EXPO_PUBLIC_CHATWOOT_BASE_URL=

# -------------------------------------------
# Firebase / Google Services
# -------------------------------------------
GOOGLE_SERVICES_JSON=
GOOGLE_SERVICE_INFO_PLIST=
EXPO_PUBLIC_IOS_GOOGLE_SERVICES_FILE=
EXPO_PUBLIC_ANDROID_GOOGLE_SERVICES_FILE=

# -------------------------------------------
# Sentry Error Tracking
# -------------------------------------------
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ORG_NAME=
EXPO_PUBLIC_SENTRY_PROJECT_NAME=
SENTRY_AUTH_TOKEN=

# -------------------------------------------
# Apple (iOS builds)
# -------------------------------------------
EXPO_APPLE_ID=
EXPO_APPLE_TEAM_ID=

# -------------------------------------------
# External Services
# -------------------------------------------
EXPO_PUBLIC_JUNE_SDK_KEY=
EXPO_PUBLIC_S3_BASE_URL=
EXPO_PUBLIC_OPENAI_API_KEY=

# -------------------------------------------
# Development Tools
# -------------------------------------------
# Enable Storybook UI: true | false
EXPO_STORYBOOK_ENABLED=false
