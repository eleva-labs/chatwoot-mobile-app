# =============================================================================
# Chatscommerce Mobile App - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# For team members: Use `pnpm run env:pull:dev` to get values from EAS.
# =============================================================================

# -----------------------------------------------------------------------------
# Environment (Required)
# -----------------------------------------------------------------------------
# Options: dev, prod
ENVIRONMENT=dev

# -----------------------------------------------------------------------------
# Chatwoot API Configuration (Required)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_BASE_URL=https://dev.app.chatscommerce.com
EXPO_PUBLIC_INSTALLATION_URL=https://dev.app.chatscommerce.com/
EXPO_PUBLIC_CHATWOOT_BASE_URL=
EXPO_PUBLIC_CHATWOOT_WEBSITE_TOKEN=
EXPO_PUBLIC_MINIMUM_CHATWOOT_VERSION=3.13.0

# -----------------------------------------------------------------------------
# Expo/EAS Configuration (Required)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_PROJECT_ID=c388de6e-16cf-4618-b94e-a45c450845dc
EXPO_PUBLIC_APP_SLUG=chatscommerce

# -----------------------------------------------------------------------------
# Firebase Configuration (Optional - for setup script)
# -----------------------------------------------------------------------------
# Override Firebase Project ID (defaults based on ENVIRONMENT)
# Development default: chatscommerce-dev
# Production default: chatscommerce-ec2f7
# FIREBASE_PROJECT_ID=

# Google Services files - usually set by EAS or credentials directory
# GOOGLE_SERVICES_JSON=
# GOOGLE_SERVICE_INFO_PLIST=
# EXPO_PUBLIC_IOS_GOOGLE_SERVICES_FILE=
# EXPO_PUBLIC_ANDROID_GOOGLE_SERVICES_FILE=

# -----------------------------------------------------------------------------
# Analytics & Monitoring (Optional)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_PROJECT_NAME=chatscommerce
EXPO_PUBLIC_SENTRY_ORG_NAME=eleva-labs
EXPO_PUBLIC_JUNE_SDK_KEY=

# Sentry auth token for source map uploads (keep secret!)
# SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Apple Configuration (for iOS submissions)
# -----------------------------------------------------------------------------
# EXPO_APPLE_ID=
# EXPO_APPLE_TEAM_ID=

# -----------------------------------------------------------------------------
# Development Flags
# -----------------------------------------------------------------------------
EXPO_STORYBOOK_ENABLED=false
SENTRY_DISABLE_AUTO_UPLOAD=true
