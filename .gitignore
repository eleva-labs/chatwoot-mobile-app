# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ============================================================================
# Dependencies
# ============================================================================
node_modules/

# ============================================================================
# Expo & React Native
# ============================================================================
.expo/
dist/
web-build/

# Native build output directories (created by expo prebuild/run)
/android/
/ios/

# ============================================================================
# Native Files & Certificates
# ============================================================================
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# ============================================================================
# Metro Bundler
# ============================================================================
.metro-health-check*

# ============================================================================
# Logs & Debug
# ============================================================================
npm-debug.*
yarn-debug.*
yarn-error.*

# ============================================================================
# macOS
# ============================================================================
.DS_Store

# ============================================================================
# Environment Variables
# ============================================================================
.env
.env.local
.env*.local
dev.env
prod.env

# Maestro test credentials (use .env.maestro.example as template)
.env.maestro

# ============================================================================
# TypeScript
# ============================================================================
*.tsbuildinfo

# ============================================================================
# Firebase & Google Services Credentials
# ============================================================================
/credentials/
/google-services.json
/GoogleService-Info.plist
android/app/google-services.json
ios/GoogleService-Info.plist
service-account-key.json

# ============================================================================
# Maestro UI Testing
# ============================================================================
# Ignore screenshots and test artifacts generated during Maestro test runs
maestro/**/*.png
maestro/**/*.jpg
maestro/**/*.jpeg
.maestro/tests/

# ============================================================================
# Documentation
# ============================================================================
# Temporary documentation
/docs/temp/
/docs/ignored/