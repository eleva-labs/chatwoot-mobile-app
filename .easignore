# EAS ignore file - overrides .gitignore for EAS builds
# This allows credentials to be included in local builds

# Keep credentials directory for local builds
# /credentials/

# Still ignore sensitive files that shouldn't be in any build
*.pem
*.key
*.p8
*.p12
*.jks
*.mobileprovision
service-account-key.json

# Ignore local environment files
.env*.local
dev.env
prod.env

# Exclude native directories so EAS always runs expo prebuild
# This ensures app.config.ts processes googleServicesFile from EAS secrets correctly
/android/
/ios/
