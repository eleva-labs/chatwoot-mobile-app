# Maestro E2E Test Environment Variables
# ======================================
# Copy to .env.maestro.local and fill in values

# Backend Selection
BACKEND_URL=http://localhost:3000

# Agent credentials (default test user)
E2E_USER_EMAIL=e2e-agent@chatwoot.local
E2E_USER_PASSWORD=Password1!

# Admin credentials (for admin-only tests)
E2E_ADMIN_EMAIL=e2e-admin@chatwoot.local
E2E_ADMIN_PASSWORD=Password1!
