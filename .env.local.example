# ===========================================
# Local-Only Environment Variables
# ===========================================
# Copy to .env.local (which is gitignored)
# These values should NOT be synced to EAS
#
# Quick setup: run 'task setup-local-env' to auto-create

# -------------------------------------------
# Sentry Configuration
# -------------------------------------------
# Disable Sentry source map uploads for local development
# This prevents authentication errors during local builds
SENTRY_DISABLE_AUTO_UPLOAD=true

# -------------------------------------------
# Build Configuration
# -------------------------------------------
# Build for simulator (1) or device (0)
# Simulator builds skip code signing
SIMULATOR=1
