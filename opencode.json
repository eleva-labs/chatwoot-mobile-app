{
  "$schema": "https://opencode.ai/schema.json",
  "model": "anthropic/claude-sonnet-4-5-20250929",
  "mcp": {
    "helicone": {
      "type": "local",
      "command": ["npx", "-y", "@helicone/mcp@latest"],
      "enabled": true,
      "environment": {
        "HELICONE_API_KEY": "{env:HELICONE_API_KEY}"
      }
    }
  },
  "agent": {
    "build": {
      "tools": {
        "helicone_*": false
      }
    },
    "plan": {
      "tools": {
        "helicone_*": false
      }
    },
    "general": {
      "tools": {
        "helicone_*": false
      }
    },
    "observability": {
      "model": "anthropic/claude-sonnet-4-5-20250929 "
    }
  }
}
