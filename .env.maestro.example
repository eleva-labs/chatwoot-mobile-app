# Maestro E2E Test Environment Variables
# ======================================
# NOTE: All variables must use MAESTRO_ prefix to be auto-injected into flows

# iOS Simulator Configuration
SIMULATOR=iPhone 17 Pro

# App ID Configuration  
# Change this value to test different environments:
#   - com.chatscommerce.app.dev (development)
#   - com.chatscommerce.app (production)
MAESTRO_APP_ID=com.chatscommerce.app.dev

# Backend URL (default to local, override for dev/prod)
MAESTRO_BACKEND_URL=https://dev.app.chatscommerce.com

# Test Credentials (auto-available in flows)
MAESTRO_E2E_USER_EMAIL=e2e-agent@chatwoot.local
MAESTRO_E2E_USER_PASSWORD=Password1!
MAESTRO_E2E_ADMIN_EMAIL=e2e-admin@chatwoot.local
MAESTRO_E2E_ADMIN_PASSWORD=Password1!
